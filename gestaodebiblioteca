-- Desafios

Escreva uma consulta para obter todos os livros emprestados no momento, incluindo o título do livro, nome do autor e a data de empréstimo.

SELECT 
  E.ID_Livro, 
  L.Titulo, 
  A.Nome, 
  E.DatadoEmprestimo
FROM Livros L
JOIN Emprestimos E
on L.ID_Livro = e.ID_Livro
JOIN Autores A
ON L.ID_Autora = a.ID_Autora
ORDER BY A.Nome

Escreva uma consulta para encontrar o autor com mais livros emprestados no momento.

SELECT a.Nome, 
	COUNT(E.ID_EMPRESTIMO) AS AutoresMaisLivrosEmprestados
FROM Autores a
JOIN Livros L
ON A.ID_Autora = L.ID_Autora
JOIN Emprestimos E
ON L.ID_Livro = E.ID_Livro
GROUP BY A.Nome
ORDER BY COUNT(E.ID_EMPRESTIMO) DESC



Escreva uma consulta para listar todos os livros que ainda não foram emprestados.

SELECT L.Titulo, E.DatadoEmprestimo
FROM Autores A
INNER JOIN Livros L
ON A.ID_Autora = L.ID_Autora
LEFT JOIN Emprestimos E
ON L.ID_Livro = E.ID_Livro
WHERE E.DatadoEmprestimo IS NULL 

Escreva uma consulta para listar todos os livros que foram emprestados.

SELECT L.Titulo, E.DatadoEmprestimo
FROM Autores A
JOIN Livros L
ON A.ID_Autora = L.ID_Autora
JOIN Emprestimos E
ON L.ID_Livro = E.ID_Livro

