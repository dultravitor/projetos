-- Criando o Banco de Dados

CREATE DATABASE gestao_de_biblioteca

 -- Usando o Banco de Dados

USE gestao_de_biblioteca

 -- Criando as tabelas
 
  CREATE TABLE Autores (
	ID_Autora INT IDENTITY(1,1) NOT NULL
		CONSTRAINT pk__ID_Autora PRIMARY KEY,
	Nome VARCHAR(200)
);

 CREATE TABLE Livros (
	ID_Livro INT IDENTITY(1,1) NOT NULL
		CONSTRAINT pk__book_id PRIMARY KEY,
	Titulo VARCHAR(200) NOT NULL,
	ID_Autora INT NOT NULL
		CONSTRAINT fk__ID_Autora__ID_Autora FOREIGN KEY REFERENCES [Autores](ID_Autora),
	AnodePublicacao VARCHAR(4)
 );

CREATE TABLE Emprestimos (
	ID_Emprestimo INT IDENTITY(1,1) NOT NULL
		CONSTRAINT pk_ID_Emprestimo PRIMARY KEY,
	ID_Livro INT NOT NULL
		CONSTRAINT fk__ID_Livro_ID_Livro FOREIGN KEY REFERENCES [Livros](ID_Livro),
	DatadoEmprestimo DATE,
	DatadoRetorno DATE
);

